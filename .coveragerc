[run]
# Focus coverage on actual system architecture
# Explicitly include service app directories where the actual code lives
source = 
    src
    services/query-analyzer/analyzer_app
    services/cache/cache_app
    services/api-gateway/gateway_app
    services/retriever/retriever_app
    services/generator/generator_app
    services/analytics/analytics_app

# Exclude test files, build artifacts, demo files, and legacy code
omit = 
    tests/*
    */tests/*
    */test_*
    */__pycache__/*
    */build/*
    */dist/*
    */venv/*
    */env/*
    */.git/*
    # Demo and presentation files (not part of core system)
    demo/*
    */demo/*
    *_demo.py
    */demos/*
    scripts/demos/*
    scripts/streamlit_*
    # Legacy/archive code
    src/legacy/*
    src/archive/*
    # Development/debug files
    src/debug/*
    */debug_*
    # Migration scripts
    migrate_*.py

# Enable branch coverage for better analysis
branch = true
parallel = true

[report]
# Show missing lines in coverage reports
show_missing = true
precision = 2

# Set coverage failure threshold
fail_under = 50

# Skip covered files in report for cleaner output
skip_covered = false
skip_empty = true

# Lines to exclude from coverage
exclude_lines =
    # Standard exclusions
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    
    # Type checking imports
    if TYPE_CHECKING:
    
    # Debug/development code
    if DEBUG:
    if DEVELOPMENT:
    
    # Logging statements (optional)
    logger\.debug
    
    # Abstract methods
    @abstractmethod

[paths]
# Map different execution contexts to same logical source
# This helps when running tests from different directories or in CI/CD
source = 
    src/
    /Users/*/rag-portfolio/project-1-technical-rag/src/
    services/*/analyzer_app/
    services/*/cache_app/
    services/*/gateway_app/
    services/*/retriever_app/
    services/*/generator_app/
    services/*/analytics_app/

[html]
# HTML report configuration
directory = reports/coverage/html
title = RAG Portfolio Coverage Report

[xml]
# XML report for CI/CD integration
output = reports/coverage/coverage.xml

[json]
# JSON report for programmatic analysis
output = reports/coverage/coverage.json

