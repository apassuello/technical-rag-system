[run]
# Focus coverage on actual system architecture
source = src, services

# Exclude test files, build artifacts, and legacy code
omit = 
    tests/*
    */tests/*
    */test_*
    */__pycache__/*
    */build/*
    */dist/*
    */venv/*
    */env/*
    */.git/*
    # Legacy/archive code
    src/legacy/*
    src/archive/*
    # Development/debug files
    src/debug/*
    */debug_*
    # Migration scripts
    migrate_*.py

# Enable branch coverage for better analysis
branch = true
parallel = true

[report]
# Show missing lines in coverage reports
show_missing = true
precision = 2

# Set coverage failure threshold
fail_under = 50

# Skip covered files in report for cleaner output
skip_covered = false
skip_empty = true

# Lines to exclude from coverage
exclude_lines =
    # Standard exclusions
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    
    # Type checking imports
    if TYPE_CHECKING:
    
    # Debug/development code
    if DEBUG:
    if DEVELOPMENT:
    
    # Logging statements (optional)
    logger\.debug
    
    # Abstract methods
    @abstractmethod

[paths]
# Architecture-aligned path mapping
source = 
    src/
    services/

[html]
# HTML report configuration
directory = reports/coverage/html
title = RAG Portfolio Coverage Report

[xml]
# XML report for CI/CD integration
output = reports/coverage/coverage.xml

[json]
# JSON report for programmatic analysis
output = reports/coverage/coverage.json

