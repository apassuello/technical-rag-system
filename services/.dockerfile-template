# Epic 8 Service Dockerfile Template
# Multi-stage build with project-root context
# Build from project root: docker build -f services/{service}/Dockerfile .

# Stage 1: Dependencies and build environment
FROM python:3.11-slim as builder

# Set build arguments
ARG BUILDPLATFORM
ARG TARGETPLATFORM
ARG SERVICE_NAME

# Install system dependencies for building
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy requirements from service directory
COPY services/${SERVICE_NAME}/requirements.txt /tmp/requirements.txt

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /tmp/requirements.txt

# Download spaCy model if needed (for query-analyzer)
RUN if [ "${SERVICE_NAME}" = "query-analyzer" ]; then \
        python -m spacy download en_core_web_sm; \
    fi

# Stage 2: Runtime environment
FROM python:3.11-slim

# Set metadata labels
ARG SERVICE_NAME
ARG SERVICE_VERSION=1.0.0
LABEL maintainer="RAG Portfolio Project"
LABEL service="${SERVICE_NAME}"
LABEL version="${SERVICE_VERSION}"
LABEL description="${SERVICE_NAME} microservice for Epic 8 RAG platform"

# Create non-root user for security
RUN groupadd -r appuser && useradd -r -g appuser appuser

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONPATH="/app"

# Copy virtual environment from builder stage
COPY --from=builder /opt/venv /opt/venv

# Create app directory and set permissions
WORKDIR /app
RUN mkdir -p /app/logs /app/cache /app/data && \
    chown -R appuser:appuser /app

# Copy Epic 1 components (src/ and config/ from project root)
COPY --chown=appuser:appuser src/ ./src/
COPY --chown=appuser:appuser config/ ./config/

# Copy service-specific application code
COPY --chown=appuser:appuser services/${SERVICE_NAME}/app/ ./app/

# Copy service configuration if exists
COPY --chown=appuser:appuser services/${SERVICE_NAME}/config.yaml ./config.yaml 2>/dev/null || true

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Switch to non-root user
USER appuser

# Service-specific configurations will be set in individual Dockerfiles